---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>

			<!-- HERO -->
			<section>
				<h1>Estudiante de Ingeniería Informática</h1>
				<p>
					Interesado en ciberseguridad, hacking ético y protección de sistemas.
				</p>
				<a href="/proyectos">Ver proyectos</a>
				<a href="/contact">Contactar</a>
			</section>

			<!-- ÁREAS DE INTERÉS -->
			<section>
				<h2>Áreas de interés</h2>
				<ul>
					<li>Pentesting</li>
					<li>Análisis de vulnerabilidades</li>
					<li>Seguridad en redes</li>
					<li>CTFs y retos de hacking</li>
				</ul>
			</section>

			<!-- PROYECTOS -->
			<section>
				<h2>🚀 Proyectos destacados</h2>
				<ul>
					<li>
						<h3>Scanner de puertos en Python</h3>
						<p>Herramienta básica para análisis de red usando sockets.</p>
					</li>
					<li>
						<h3>Writeups de CTF</h3>
						<p>Resolución y documentación de retos de ciberseguridad.</p>
					</li>
				</ul>
				<a href="/projects">Ver todos los proyectos</a>
			</section>

			<!-- STACK -->
			<section>
				<h2>Tecnologías</h2>
				<p>
					Python · Linux · Bash · Git · Docker · Wireshark · Nmap
				</p>
			</section>

			<!-- ACTUALMENTE -->
			<section>
				<h2>Actualmente</h2>
				<p>
					Aprendiendo explotación de vulnerabilidades web y participando en CTFs.
				</p>
			</section>

			<!-- CTA -->
			<section>
				<h2>¿Hablamos?</h2>
				<p>
					Buscando prácticas, colaboración en proyectos y seguir aprendiendo.
				</p>
				<a href="/contact">Contactar</a>
			</section>

		</main>

		<Footer />
	</body>
</html>